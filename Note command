# Note command for OS 
- Auto completion cho các CLI: 
velero completion bash | sudo tee /etc/bash_completion.d/velero > /dev/null

- Rescan khi có disk mới
for host in /sys/class/scsi_host/host*/scan; do echo "- - -" > $host; done

- Comment swap trong fstab
sed -i 's/^[^#]*swap/#&/' /etc/fstab


# Note command for Kubernetes
- Change default namespace for kubectl command
kubectl config set-context --current --namespace=ABC

- Xóa ns treo ở Termination:
kubectl get ns velero -o json | jq '.spec.finalizers = []' | kubectl replace --raw "/api/v1/namespaces/velero/finalize" -f -

- Set default storage class
oc patch storageclass <sc-name> -p '{"metadata": {"annotations": {"storageclass.kubernetes.io/is-default-class":"true"}}}'

- Fillter by timestamps
oc get events --sort-by='.lastTimestamp'
